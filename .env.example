# Copy to .env and fill in values
# Example: https://api.staging.example.com
BASE_URL=
# Your tenant name
TENANT=
# Bearer token from localStorage (copy full "Bearer xxx..." value)
AUTH_TOKEN=
# Path to OpenAPI spec (already included in repo)
OPENAPI_SPEC_PATH=./api.v1.compiled.yml
# Supplier/External endpoint auth (uses x-supplier-auth header)
SUPPLIER_TOKEN=
SUPPLIER_ID=
SUPPLIER_TENANT=